{
  "name": "context-switch",
  "version": "1.0.0",
  "description": "Context Switching Recovery Agent — an MCP server that reconstructs your working context after interruptions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-switch": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "context-switch",
    "mcp",
    "mcp-server",
    "developer-tools",
    "productivity",
    "git",
    "workflow"
  ],
  "author": "Vinit Shahdeo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
